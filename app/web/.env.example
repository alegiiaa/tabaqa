# Tabaqa web — environment template.
# Copy to `.env.local` (git-ignored) and fill in from your Supabase project:
#   Supabase Dashboard → Project Settings → API
#   - Project URL          → VITE_SUPABASE_URL
#   - Project API keys: anon / public → VITE_SUPABASE_ANON_KEY
# Restart `npm run dev` after editing (Vite only reads env at startup).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Base URL of the Tabaqa API.
#   - Local dev: leave EMPTY — the Vite dev server proxies /v1 → http://localhost:8000.
#   - Production (Vercel): set to your deployed API origin, e.g. https://tabaqa-api.onrender.com
VITE_API_BASE=
