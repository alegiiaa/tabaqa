{
  "name": "tabaqa-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Tabaqa — landing page + demo dashboard (React + Vite)",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "ios:local": "VITE_API_BASE=http://localhost:8000 npm run build && cap sync ios",
    "ios:lan": "VITE_API_BASE=http://$(ipconfig getifaddr en0):8000 npm run build && cap sync ios",
    "ios:prod": "VITE_API_BASE=https://tabaqa-api.vercel.app npm run build && cap sync ios"
  },
  "dependencies": {
    "@capacitor/cli": "^7.6.8",
    "@capacitor/core": "^7.6.8",
    "@capacitor/dialog": "^7.0.4",
    "@capacitor/ios": "^7.6.8",
    "@capacitor/splash-screen": "^7.0.5",
    "@supabase/supabase-js": "^2.108.2",
    "@types/qrcode-generator": "^0.0.16",
    "framer-motion": "^12.40.0",
    "qrcode-generator": "^2.0.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
